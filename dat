-- View All Expenses
SELECT * FROM Expenses;

-- View Expenses with Category Name
SELECT 
    e.expense_id,
    u.username,
    c.category_name,
    e.amount,
    e.expense_date,
    e.description
FROM Expenses e
JOIN Users u 
ON e.user_id = u.user_id
JOIN Categories c
ON e.category_id = c.category_id;

-- Total Expense by User
SELECT 
    u.username,
    SUM(e.amount) AS total_expense
FROM Expenses e
JOIN Users u
ON e.user_id = u.user_id
GROUP BY u.username;

-- Category-wise Expense Report
SELECT 
    c.category_name,
    SUM(e.amount) AS total_spent
FROM Expenses e
JOIN Categories c
ON e.category_id = c.category_id
GROUP BY c.category_name;

-- Find Expenses Greater Than 500
SELECT * 
FROM Expenses
WHERE amount > 500;

-- Update Expense Amount
UPDATE Expenses
SET amount = 300
WHERE expense_id = 1;

-- Delete an Expense
DELETE FROM Expenses
WHERE expense_id = 3;

-- Create View for Monthly Report
CREATE VIEW MonthlyExpenseReport AS
SELECT 
    u.username,
    c.category_name,
    e.amount,
    e.expense_date
FROM Expenses e
JOIN Users u
ON e.user_id = u.user_id
JOIN Categories c
ON e.category_id = c.category_id;

-- Display View
SELECT * FROM MonthlyExpenseReport;
